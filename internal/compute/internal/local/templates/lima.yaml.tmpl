vmType: vz
arch: {{ .Arch }}
cpus: {{ .CPUs }}
memory: {{ .Memory }}
disk: {{ .Disk }}
images:
  - location: {{ .ImagePath }}
    arch: {{ .Arch }}
# The machine image must include containerd and all required services
# pre-configured.
containerd:
  system: false
  user: false
mountType: virtiofs
mounts:
  - location: {{ .Home }}
    writable: true
provision:
  # Add the Lima user to the containerd group so the SSH port-forward can
  # relay traffic from the host. Fix /run/containerd group ownership before
  # (re)starting containerd; without this, containerd creates the directory
  # as root:root 0711 and the Lima user cannot create FIFO directories for
  # task exec IO.
  - mode: system
    script: |
      #!/bin/sh
      set -eu
      addgroup {{ .User }} containerd 2>/dev/null || true
      rc-service containerd stop 2>/dev/null || true
      mkdir -p /run/containerd
      chgrp containerd /run/containerd
      chmod 775 /run/containerd
      rc-service containerd start
probes:
  - mode: readiness
    description: containerd to be running
    script: |
      #!/bin/sh
      test -S /run/containerd/containerd.sock
    hint: containerd is not running
# Forward the containerd Unix socket from the guest to the host. Unix domain
# sockets on virtiofs are visible on both sides but the kernel socket state
# does not cross the boundary. Lima tunnels the connection over SSH so the
# host can dial its local path transparently.
portForwards:
  - guestSocket: "{{ .GuestSocket }}"
    hostSocket: "{{ .HostSocket }}"
